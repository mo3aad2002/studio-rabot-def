<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Serve existing files and directories as-is (sitemap.xml, llms.txt, robots.txt, assets, etc.)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Fall back to the SPA entry point for all other routes
  RewriteRule ^ index.html [L]
</IfModule>
